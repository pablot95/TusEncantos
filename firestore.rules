rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Productos: lectura pública, escritura solo admin autenticado.
    // Se permite reducir el stock sin auth (solo el campo stock, valores >= 0)
    // para que el checkout pueda descontar unidades al confirmar el pago.
    // El stock es ahora un mapa por talle: { XS: n, S: n, M: n, L: n, XL: n, XXL: n }
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
         request.resource.data.stock is map &&
         request.resource.data.stock.get('XS', 0) >= 0 &&
         request.resource.data.stock.get('S', 0) >= 0 &&
         request.resource.data.stock.get('M', 0) >= 0 &&
         request.resource.data.stock.get('L', 0) >= 0 &&
         request.resource.data.stock.get('XL', 0) >= 0 &&
         request.resource.data.stock.get('XXL', 0) >= 0);
    }

    // Órdenes: cualquiera puede crear con status 'pending' o 'pending_transfer'.
    // Solo admin puede leer y eliminar.
    // Se permite leer una orden sin auth (el orderId random actúa como secret)
    // para poder enviar el email de confirmación al volver de MercadoPago.
    // Se permite cambiar a 'approved' sin auth (retorno de MercadoPago).
    match /orders/{orderId} {
      allow create: if request.resource.data.status == 'pending' ||
                       request.resource.data.status == 'pending_transfer';
      allow read: if request.auth != null || true; // orderId es unguessable
      allow update: if request.auth != null ||
        (resource.data.status == 'pending' &&
         request.resource.data.status == 'approved' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'approvedAt']));
      allow delete: if request.auth != null;
    }
  }
}
